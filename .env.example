# Copy this file to .env and fill in your credentials
# .env is never committed to version control

# --- Email Alerts (Gmail) ---
GMAIL_ADDRESS=your_gmail_here@gmail.com        # Gmail address you send FROM
GMAIL_APP_PASSWORD=your_app_password_here      # App password from Google (not your login password)
ALERT_TO_EMAIL=your_gmail_here@gmail.com       # Email address to send alerts TO (can be same or different)

# --- Alpaca (Paper Trading — Phase 2) ---
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
